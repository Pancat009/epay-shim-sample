PORT=3000
# 公网可访问地址，支付宝/微信回调要用，不要带末尾斜杠
PUBLIC_BASE=https://your-domain.example.com

# 易支付协议侧（NewAPI 那边填这两个）
EPAY_PID=1000
EPAY_KEY=replace-with-a-long-random-secret

# 支付宝当面付（开放平台 -> 应用 -> 密钥）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 微信支付 v2（商户平台 -> 账户中心 -> API安全）
WX_APP_ID=
WX_MCH_ID=
WX_API_KEY=
